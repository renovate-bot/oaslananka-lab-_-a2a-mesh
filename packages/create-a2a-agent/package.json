{
  "name": "create-a2a-mesh",
  "version": "1.4.0",
  "description": "Bootstrap a new A2A agent project with a2a-mesh templates and adapter presets",
  "keywords": [
    "a2a",
    "agent2agent",
    "ai-agents",
    "scaffold",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh/tree/main/packages/create-a2a-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/create-a2a-agent"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "create-a2a-mesh": "dist/index.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "unbuild --config build.config.ts"
  },
  "dependencies": {
    "a2a-mesh-cli": "workspace:^"
  }
}
