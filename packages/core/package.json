{
  "name": "a2a-mesh",
  "version": "1.4.0",
  "description": "A2A Protocol v1.0 server runtime, task model, auth, telemetry and middleware",
  "keywords": [
    "a2a",
    "agent2agent",
    "ai-agents",
    "multi-agent",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "eventsource": "^2.0.2",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/express": "^5.0.6",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "better-sqlite3": "^12.9.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.mjs",
      "require": "./dist/middleware/index.cjs"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.mjs",
      "require": "./dist/telemetry/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
