{
  "name": "a2a-mesh-codex-bridge",
  "private": true,
  "version": "1.0.0",
  "description": "Experimental bridge utilities for connecting Codex/App Server tools to a2a-mesh agents and registries",
  "keywords": [
    "a2a",
    "agent2agent",
    "codex",
    "mcp",
    "tool-calling",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh/tree/main/packages/codex-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/codex-bridge"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "unbuild --config build.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "a2a-mesh": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "type": "module",
  "engines": {
    "node": "^22.13.0 || ^24.0.0",
    "pnpm": ">=11 <12"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
