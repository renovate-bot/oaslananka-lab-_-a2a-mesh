{
  "name": "a2a-mesh-grpc",
  "private": true,
  "version": "1.0.0",
  "description": "gRPC transport bindings for a2a-mesh A2A Protocol runtimes",
  "keywords": [
    "a2a",
    "agent2agent",
    "grpc",
    "typescript",
    "transport"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/grpc"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "proto:gen": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:src/generated --grpc_out=grpc_js:src/generated --proto_path=proto proto/a2a.proto",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "a2a-mesh": "^1.2.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "proto"
  ]
}
