    "llamaindex": "^0.9.11",
    "openai": "^4.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "langchain": {
      "optional": true
    },
    "llamaindex": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "langchain": "^1.2.39",
    "llamaindex": "^0.9.11",
    "openai": "^4.104.0",
    "typescript": "^5.2.2"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
