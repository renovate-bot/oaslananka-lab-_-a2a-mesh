{
  "name": "a2a-mesh-adapters",
  "version": "1.2.0",
  "description": "Multi-framework adapters for OpenAI, Anthropic, LangChain, Google ADK, CrewAI and LlamaIndex",
  "keywords": [
    "a2a",
    "agent2agent",
    "openai",
    "anthropic",
    "langchain",
    "llamaindex",
    "crewai",
    "google-adk"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/adapters"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "a2a-mesh": "workspace:^"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0 || ^0.95.0",
    "langchain": "^0.3.37 || ^1.0.0",
    "llamaindex": "^0.9.11 || ^0.12.0",
    "openai": "^4.20.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "langchain": {
      "optional": true
    },
    "llamaindex": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "langchain": "^1.2.39",
    "openai": "^6.37.0",
    "typescript": "^5.2.2",
    "zod": "^4.4.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
