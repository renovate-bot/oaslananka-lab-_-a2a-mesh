    "openai",
    "anthropic",
    "langchain",
    "llamaindex",
    "crewai",
    "google-adk"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "packages/adapters"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
