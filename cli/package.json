{
  "name": "a2a-mesh-cli",
  "version": "1.4.0",
  "description": "CLI for validating, discovering, benchmarking and operating A2A agents",
  "keywords": [
    "a2a",
    "agent2agent",
    "cli",
    "typescript",
    "tooling"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oaslananka/a2a-mesh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-mesh.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-mesh/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "bin": {
    "a2a": "dist/index.cjs"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "start": "node dist/index.cjs",
    "test": "vitest run"
  },
  "dependencies": {
    "a2a-mesh": "workspace:^",
    "a2a-mesh-registry": "workspace:^",
    "commander": "^11.1.0",
    "chalk": "^5.6.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^22.17.2"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
