{
  "title": "a2a-mesh Overview",
  "timezone": "browser",
  "panels": [
    {
      "title": "Registered Agents",
      "type": "stat",
      "targets": [{ "expr": "a2a_registry_agents" }]
    },
    {
      "title": "Healthy Agents",
      "type": "stat",
      "targets": [{ "expr": "a2a_registry_healthy_agents" }]
    },
    {
      "title": "Active Tenants",
      "type": "stat",
      "targets": [{ "expr": "a2a_registry_active_tenants" }]
    },
    {
      "title": "Public Agents",
      "type": "stat",
      "targets": [{ "expr": "a2a_registry_public_agents" }]
    },
    {
      "title": "Registrations",
      "type": "timeseries",
      "targets": [{ "expr": "rate(a2a_registry_registrations_total[5m])" }]
    },
    {
      "title": "Registry Searches",
      "type": "timeseries",
      "targets": [{ "expr": "rate(a2a_registry_searches_total[5m])" }]
    },
    {
      "title": "Heartbeats",
      "type": "timeseries",
      "targets": [{ "expr": "rate(a2a_registry_heartbeats_total[5m])" }]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
